# ============================================================
# TruthBridge — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Supabase Project (from supabase.com dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# OpenWeatherMap API (from openweathermap.org)
VITE_OPENWEATHER_KEY=your_openweather_key_here

# Hugging Face Inference API - AI-generated image detection
HUGGING_FACE_API_KEY=your_huggingface_api_key_here
