# ============================================================
# TruthBridge — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Supabase Project (from supabase.com dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# OpenWeatherMap API (from openweathermap.org)
VITE_OPENWEATHER_KEY=your_openweather_key_here

# Hive Moderation API (from hivemoderation.com) - AI-generated image detection
VITE_HIVE_API_KEY=your_hive_api_key_here
